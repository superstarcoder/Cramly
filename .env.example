# Required — OpenAI API key for quiz generation, study guide, and answer grading
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Optional — Tavily API key for web research enrichment
# When set, Cramly automatically runs targeted web searches before generating
# quizzes and study guides, adding high-quality external sources to the context.
# Get a free key (1000 searches/month) at https://app.tavily.com
TAVILY_API_KEY=your_tavily_key_here
